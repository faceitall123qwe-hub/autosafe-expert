---
import { content, brand, type Locale } from '../data/content';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const langs: { code: Locale; label: string; path: string }[] = [
  { code: 'pl', label: 'PL', path: '' },
  { code: 'uk', label: 'UA', path: 'uk/' },
  { code: 'en', label: 'EN', path: 'en/' },
  { code: 'ru', label: 'RU', path: 'ru/' },
  { code: 'be', label: 'BY', path: 'be/' },
];

const telHref = `tel:${brand.phoneHref}`;
const waHref = `https://wa.me/${brand.whatsapp.replace(/[^0-9]/g, '')}`;
const mailSubject = encodeURIComponent(`${t.contact.title} — ${brand.name}`);
const mailHref = `mailto:${brand.email}?subject=${mailSubject}`;

const icons: Record<string, string> = {
  shield: 'M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3Z',
  wrench: 'M14.7 6.3a4.5 4.5 0 0 0-6 6L3 18l3 3 5.7-5.7a4.5 4.5 0 0 0 6-6L14 13l-3-3 3.7-3.7Z',
  doc: 'M6 2h9l5 5v15H6V2Zm9 0v5h5M8 12h8M8 16h8',
  star: 'm12 2 3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6Z',
};
---

<!-- HEADER -->
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-[var(--color-line)]">
  <div class="container-x flex items-center justify-between h-16">
    <a href={`${base}/${langs.find((l) => l.code === locale)!.path}`} class="flex items-center gap-2 text-[var(--color-ink)] font-bold text-lg">
      <span class="grid place-items-center w-8 h-8 rounded-lg bg-[var(--color-brand)] text-white">A</span>
      {brand.name}
    </a>
    <nav class="hidden lg:flex items-center gap-6 text-sm text-[var(--color-muted)]">
      <a href="#uslugi" class="hover:text-[var(--color-brand)]">{t.nav.services}</a>
      <a href="#ekspert" class="hover:text-[var(--color-brand)]">{t.nav.expert}</a>
      <a href="#cennik" class="hover:text-[var(--color-brand)]">{t.nav.pricing}</a>
      <a href="#jak" class="hover:text-[var(--color-brand)]">{t.nav.process}</a>
      <a href="#faq" class="hover:text-[var(--color-brand)]">{t.nav.faq}</a>
    </nav>
    <div class="flex items-center gap-3">
      <nav class="flex items-center rounded-md border border-[var(--color-line)] overflow-hidden text-xs font-semibold">
        {langs.map((l) => (
          <a
            href={`${base}/${l.path}`}
            class:list={[
              'px-1.5 sm:px-2 py-1.5',
              l.code === locale
                ? 'bg-[var(--color-brand)] text-white'
                : 'text-[var(--color-muted)] hover:text-[var(--color-brand)]',
            ]}
            aria-current={l.code === locale ? 'page' : undefined}
          >{l.label}</a>
        ))}
      </nav>
      <a href="#kontakt" class="btn btn-primary hidden sm:inline-flex text-sm">{t.nav.cta}</a>
    </div>
  </div>
</header>

<!-- HERO -->
<section class="relative bg-gradient-to-b from-[var(--color-paper)] to-white overflow-hidden">
  <div class="absolute inset-0 opacity-60 pointer-events-none" style="background:radial-gradient(700px 340px at 82% -20%, rgba(37,99,235,0.12), transparent)"></div>
  <div class="container-x relative py-16 md:py-24 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <span class="inline-block text-xs font-semibold tracking-wide uppercase text-[var(--color-brand)] bg-[var(--color-brand)]/10 border border-[var(--color-brand)]/20 rounded-full px-3 py-1">{t.hero.badge}</span>
      <h1 class="mt-5 text-3xl md:text-5xl font-bold leading-tight text-[var(--color-ink)]" style="font-family:var(--font-serif)">{t.hero.title}</h1>
      <p class="mt-5 text-[var(--color-muted)] text-lg max-w-xl">{t.hero.subtitle}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#kontakt" class="btn btn-primary">{t.hero.ctaPrimary}</a>
        <a href={telHref} class="btn btn-outline">{t.hero.ctaSecondary} · {brand.phone}</a>
      </div>
      <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-[var(--color-ink-soft)]">
        {t.hero.trust.map((item) => (
          <li class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2.5"><path d="m5 12 5 5L20 7"/></svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-white border border-[var(--color-line)] rounded-2xl p-6 md:p-8 shadow-[0_20px_50px_-20px_rgba(16,42,84,0.25)]">
      <img src={`${base}/img/hero.jpg`} alt="Pomiar grubości lakieru podczas oględzin auta" class="aspect-[4/3] w-full rounded-xl object-cover" loading="eager" />
      <div class="mt-6 grid grid-cols-3 gap-4 text-center">
        <div><div class="text-2xl font-bold text-[var(--color-brand)]">15</div><div class="text-xs text-[var(--color-muted)]">lat ekspertyz</div></div>
        <div><div class="text-2xl font-bold text-[var(--color-brand)]">100 km</div><div class="text-xs text-[var(--color-muted)]">dojazd w cenie</div></div>
        <div><div class="text-2xl font-bold text-[var(--color-brand)]">od 250 zł</div><div class="text-xs text-[var(--color-muted)]">oględziny</div></div>
      </div>
    </div>
  </div>
</section>

<!-- WHY US -->
<section class="py-16 md:py-20 bg-[var(--color-paper)]">
  <div class="container-x">
    <h2 class="text-2xl md:text-3xl font-bold text-center" style="font-family:var(--font-serif)">{t.whyUs.title}</h2>
    <p class="mt-3 text-center text-[var(--color-muted)] max-w-2xl mx-auto">{t.whyUs.subtitle}</p>
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {t.whyUs.items.map((item) => (
        <div class="bg-white rounded-2xl p-6 border border-black/5 shadow-sm">
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-muted)]">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="uslugi" class="py-16 md:py-20">
  <div class="container-x">
    <h2 class="text-2xl md:text-3xl font-bold" style="font-family:var(--font-serif)">{t.services.title}</h2>
    <p class="mt-3 text-[var(--color-muted)]">{t.services.subtitle}</p>
    <div class="mt-10 grid sm:grid-cols-2 gap-6">
      {t.services.items.map((s) => (
        <div class="rounded-2xl p-7 border border-black/5 shadow-sm hover:shadow-md transition bg-white flex flex-col">
          <span class="grid place-items-center w-12 h-12 rounded-xl bg-[var(--color-brand)]/10 text-[var(--color-brand)] mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d={icons[s.icon]} /></svg>
          </span>
          <h3 class="font-semibold text-lg">{s.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-muted)] flex-1">{s.desc}</p>
          <div class="mt-5 flex items-center justify-between">
            <span class="font-bold text-[var(--color-brand)]">{s.priceFrom}</span>
            <a href="#kontakt" class="text-sm font-semibold text-[var(--color-ink)] underline underline-offset-4">{t.nav.cta} →</a>
          </div>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-[var(--color-muted)] bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/30 rounded-lg px-4 py-3">{t.services.note}</p>
  </div>
</section>

<!-- CHECKLIST -->
<section class="py-16 md:py-20 bg-[var(--color-navy)] text-white">
  <div class="container-x">
    <h2 class="text-2xl md:text-3xl font-bold" style="font-family:var(--font-serif)">{t.checklist.title}</h2>
    <p class="mt-3 text-white/70">{t.checklist.subtitle}</p>

    <div class="mt-10 inline-block rounded-full bg-white/10 border border-white/15 px-4 py-1.5 text-sm font-semibold">{t.checklist.basicLabel}</div>
    <div class="mt-5 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {t.checklist.groups.map((g) => (
        <div class="bg-white/5 border border-white/10 rounded-2xl p-5">
          <h3 class="font-semibold text-white">{g.title}</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-white/80">
            {g.items.map((i) => (
              <li class="flex gap-2"><span class="text-white/50">•</span>{i}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 inline-block rounded-full bg-[var(--color-accent)] px-4 py-1.5 text-sm font-semibold text-white">{t.checklist.extendedLabel}</div>
    <div class="mt-5 grid sm:grid-cols-2 gap-5">
      {t.checklist.extendedGroups.map((g) => (
        <div class="bg-white/5 border border-[var(--color-accent)]/50 rounded-2xl p-5">
          <h3 class="font-semibold text-[var(--color-accent)]">{g.title}</h3>
          <ul class="mt-3 space-y-1.5 text-sm text-white/80">
            {g.items.map((i) => (
              <li class="flex gap-2"><span class="text-[var(--color-accent)]">•</span>{i}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- GUARANTEE (odwrócenie ryzyka — research: redukuje obawy przed rezerwacją) -->
<section class="py-16 md:py-20">
  <div class="container-x">
    <h2 class="text-2xl md:text-3xl font-bold text-center" style="font-family:var(--font-serif)">{t.guarantee.title}</h2>
    <p class="mt-3 text-center text-[var(--color-muted)]">{t.guarantee.subtitle}</p>
    <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {t.guarantee.items.map((item) => (
        <div class="rounded-2xl p-6 border border-[var(--color-brand)]/15 bg-[var(--color-brand)]/5">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5l-8-3Z"/><path d="m9 12 2 2 4-4"/></svg>
          <h3 class="mt-3 font-semibold">{item.title}</h3>
          <p class="mt-1.5 text-sm text-[var(--color-muted)]">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- EXPERT -->
<section id="ekspert" class="py-16 md:py-20 bg-[var(--color-paper)]">
  <div class="container-x grid md:grid-cols-2 gap-10 items-start">
    <div>
      <!-- Docelowo: prawdziwe zdjęcie Iwana (podmień public/img/expert.jpg) -->
      <img src={`${base}/img/expert.jpg`} alt="Ekspert podczas oględzin samochodu" class="aspect-[3/4] max-w-sm w-full rounded-2xl object-cover" loading="lazy" />
    </div>
    <div>
      <h2 class="text-2xl md:text-3xl font-bold" style="font-family:var(--font-serif)">{t.expert.title}</h2>
      <p class="mt-4 text-lg font-medium">{t.expert.lead}</p>
      {t.expert.paragraphs.map((p) => <p class="mt-3 text-[var(--color-muted)]">{p}</p>)}
      <ul class="mt-6 space-y-2.5">
        {t.expert.credentials.map((c) => (
          <li class="flex gap-3 text-sm">
            <svg class="shrink-0 mt-0.5" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2.2"><path d="m5 12 5 5L20 7"/></svg>
            <span>{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="cennik" class="py-16 md:py-20">
  <div class="container-x max-w-3xl">
    <h2 class="text-2xl md:text-3xl font-bold text-center" style="font-family:var(--font-serif)">{t.pricing.title}</h2>
    <p class="mt-3 text-center text-[var(--color-muted)]">{t.pricing.subtitle}</p>
    <div class="mt-8 bg-white rounded-2xl border border-black/5 shadow-sm overflow-hidden">
      {t.pricing.rows.map((r, idx) => (
        <div class:list={["flex items-center justify-between px-6 py-4", idx % 2 === 1 && "bg-[var(--color-paper)]"]}>
          <span class="font-medium">{r.service}</span>
          <span class="font-bold text-[var(--color-brand)] whitespace-nowrap">{r.price}</span>
        </div>
      ))}
    </div>
    <p class="mt-4 text-sm text-[var(--color-muted)] text-center">{t.pricing.note}</p>
    <div class="mt-6 text-center"><a href="#kontakt" class="btn btn-primary">{t.pricing.cta}</a></div>
  </div>
</section>

<!-- PROCESS -->
<section id="jak" class="py-16 md:py-20 bg-[var(--color-paper)]">
  <div class="container-x">
    <h2 class="text-2xl md:text-3xl font-bold" style="font-family:var(--font-serif)">{t.process.title}</h2>
    <p class="mt-3 text-[var(--color-muted)]">{t.process.subtitle}</p>
    <div class="mt-10 grid md:grid-cols-4 gap-6">
      {t.process.steps.map((s) => (
        <div class="relative">
          <h3 class="font-semibold text-lg text-[var(--color-brand)]">{s.title}</h3>
          <p class="mt-2 text-sm text-[var(--color-muted)]">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- REVIEWS (social proof — pokazuje się dopiero gdy są prawdziwe opinie w content.ts) -->
{t.reviews.items.length > 0 && (
  <section id="opinie" class="py-16 md:py-20">
    <div class="container-x">
      <h2 class="text-2xl md:text-3xl font-bold text-center" style="font-family:var(--font-serif)">{t.reviews.title}</h2>
      <p class="mt-3 text-center text-[var(--color-muted)]">{t.reviews.subtitle}</p>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {t.reviews.items.map((r) => (
          <figure class="rounded-2xl p-6 border border-[var(--color-line)] bg-white shadow-sm">
            <div class="text-[var(--color-accent)] tracking-widest" aria-label="5/5">★★★★★</div>
            <blockquote class="mt-3 text-sm text-[var(--color-ink-soft)]">{r.text}</blockquote>
            <figcaption class="mt-4 text-sm font-semibold">{r.name} <span class="font-normal text-[var(--color-muted)]">· {r.source}</span></figcaption>
          </figure>
        ))}
      </div>
      {brand.googleReview && (
        <div class="mt-8 text-center">
          <a href={brand.googleReview} target="_blank" rel="noopener" class="btn btn-outline">{t.reviews.googleCta}</a>
        </div>
      )}
    </div>
  </section>
)}

<!-- FAQ -->
<section id="faq" class="py-16 md:py-20">
  <div class="container-x max-w-3xl">
    <h2 class="text-2xl md:text-3xl font-bold text-center" style="font-family:var(--font-serif)">{t.faq.title}</h2>
    <div class="mt-8 space-y-3">
      {t.faq.items.map((f) => (
        <details class="group bg-[var(--color-paper)] rounded-xl border border-[var(--color-line)] px-5 py-4">
          <summary class="flex items-center justify-between cursor-pointer font-medium list-none">
            {f.q}
            <span class="text-[var(--color-brand)] group-open:rotate-45 transition">+</span>
          </summary>
          <p class="mt-3 text-sm text-[var(--color-muted)]">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="kontakt" class="py-16 md:py-20 bg-[var(--color-navy)] text-white">
  <div class="container-x grid md:grid-cols-2 gap-10">
    <div>
      <h2 class="text-2xl md:text-3xl font-bold" style="font-family:var(--font-serif)">{t.contact.title}</h2>
      <p class="mt-3 text-white/75">{t.contact.subtitle}</p>
      <div class="mt-8 space-y-4 text-sm">
        <div>
          <div class="text-white/50">{t.contact.phoneLabel}</div>
          <a href={telHref} class="text-lg font-semibold hover:text-[var(--color-accent)]">{brand.phone}</a>
          <span class="text-white/40"> · </span>
          <a href={`tel:${brand.phone2Href}`} class="text-lg font-semibold hover:text-[var(--color-accent)]">{brand.phone2}</a>
        </div>
        <div><div class="text-white/50">{t.contact.emailLabel}</div><a href={mailHref} class="text-lg font-semibold hover:text-[var(--color-accent)]">{brand.email}</a></div>
        <div><div class="text-white/50">{t.contact.areaLabel}</div><div>{t.contact.area}</div></div>
        <div><div class="text-white/50">{t.contact.hoursLabel}</div><div>{t.contact.hours}</div></div>
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={telHref} class="btn btn-primary">{t.hero.ctaSecondary}</a>
        <a href={waHref} class="btn btn-ghost">WhatsApp</a>
        {brand.facebook && <a href={brand.facebook} target="_blank" rel="noopener" class="btn btn-ghost">Facebook</a>}
      </div>
    </div>
    <form
      class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-4"
      action={mailHref}
      method="get"
    >
      <div>
        <label class="text-sm text-white/70" for="name">{t.contact.formName}</label>
        <input id="name" name="name" required class="mt-1 w-full rounded-lg bg-white/10 border border-white/15 px-3 py-2.5 text-white placeholder-white/40 focus:outline-none focus:border-[var(--color-accent)]" />
      </div>
      <div>
        <label class="text-sm text-white/70" for="phone">{t.contact.formPhone}</label>
        <input id="phone" name="phone" required class="mt-1 w-full rounded-lg bg-white/10 border border-white/15 px-3 py-2.5 text-white placeholder-white/40 focus:outline-none focus:border-[var(--color-accent)]" />
      </div>
      <div>
        <label class="text-sm text-white/70" for="body">{t.contact.formMsg}</label>
        <textarea id="body" name="body" rows="3" class="mt-1 w-full rounded-lg bg-white/10 border border-white/15 px-3 py-2.5 text-white placeholder-white/40 focus:outline-none focus:border-[var(--color-accent)]"></textarea>
      </div>
      <button type="submit" class="btn btn-primary w-full">{t.contact.formSubmit}</button>
      <p class="text-xs text-white/40">{t.contact.formNote}</p>
    </form>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-[var(--color-ink)] text-white/60 py-10">
  <div class="container-x flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
    <div>
      <div class="text-white font-semibold">{brand.name}</div>
      <div class="mt-1">{t.footer.disclaimer}</div>
    </div>
    <div class="text-center sm:text-right">
      <div>{brand.phone} · {brand.phone2} · {brand.email}{brand.facebook && <> · <a href={brand.facebook} target="_blank" rel="noopener" class="hover:text-white">Facebook</a></>}</div>
      <div class="mt-1">© {new Date().getFullYear()} {brand.name}. {t.footer.rights} · <a href={`${base}/polityka-prywatnosci/`} class="hover:text-white underline underline-offset-2">{t.footer.privacy}</a></div>
    </div>
  </div>
</footer>

<!-- Pływający przycisk telefon (mobile) -->
<a href={telHref} class="lg:hidden fixed bottom-5 right-5 z-50 btn btn-primary shadow-lg rounded-full w-14 h-14 !p-0" aria-label="Telefon">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z"/></svg>
</a>
