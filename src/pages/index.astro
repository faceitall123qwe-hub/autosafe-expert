---
import Base from '../layouts/Base.astro';
import Landing from '../components/Landing.astro';
import { content } from '../data/content';
const t = content.pl;
---

<Base lang="pl" title={t.meta.title} description={t.meta.description}>
  <Landing locale="pl" otherHref={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/uk/`} otherLabel="UA" />
</Base>
